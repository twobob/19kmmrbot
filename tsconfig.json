{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build",
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/*", "build/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
